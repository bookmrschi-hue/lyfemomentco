  <div class="card-subtitle">Tell us who we're celebrating!</div>

  <div class="field-row">
    <div class="fg">
      <label>Graduate's Name <span class="req">*</span></label>
      <input type="text" id="gradName" placeholder="Exactly as it should print">
      <div class="field-error" id="err-gradName">Please enter the graduate's name</div>
    </div>
    <div class="fg">
      <label>School Name <span class="req">*</span></label>
