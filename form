    </div>
  </div>
  <div class="fg">
    <label>Email Address <span class="req">*</span></label>
    <input type="email" id="email" placeholder="you@email.com" autocomplete="email">
    <div class="field-error" id="err-email">Please enter a valid email</div>
  </div>
  <div class="fg">
    <label>Instagram Handle <span style="color:var(--muted);font-weight:700;text-transform:none;letter-spacing:0;">(optional — for tagging your order reveal)</span></label>
    <input type="text" id="instagram" placeholder="@yourusername">
  </div>
</div>

